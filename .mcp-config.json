{
  "_comment": "MCP Server 配置文件",
  "version": "1.0.0",

  "environments": {
    "development": {
      "pencil": {
        "transport": "stdio",
        "command": "node",
        "args": ["mcp-servers/pencil-mcp/server.js"]
      },
      "chromeDevTools": {
        "transport": "stdio",
        "command": "node",
        "args": ["mcp-servers/chrome-devtools-mcp/server.js"]
      },
      "playwright": {
        "transport": "stdio",
        "command": "node",
        "args": ["mcp-servers/playwright-mcp/server.js"]
      }
    },
    
    "docker": {
      "pencil": {
        "transport": "sse",
        "endpoint": "http://localhost:3001"
      },
      "chromeDevTools": {
        "transport": "sse",
        "endpoint": "http://localhost:3002"
      },
      "playwright": {
        "transport": "sse",
        "endpoint": "http://localhost:3003"
      }
    },
    
    "production": {
      "pencil": {
        "transport": "sse",
        "endpoint": "${PENCIL_MCP_ENDPOINT}"
      },
      "chromeDevTools": {
        "transport": "sse",
        "endpoint": "${CHROME_DEVTOOLS_MCP_ENDPOINT}"
      },
      "playwright": {
        "transport": "sse",
        "endpoint": "${PLAYWRIGHT_MCP_ENDPOINT}"
      }
    }
  },
  
  "defaultEnvironment": "development",
  
  "options": {
    "connectionTimeout": 30000,
    "requestTimeout": 120000,
    "maxRetries": 3
  }
}
